# Environment variables for the project
# Create a .env file by copying this file and filling in the values

# Application name
# TODO: Change this to the name of your project
APP_NAME=Template FastAPI Project

# For local development, it's convenient to enable debug
DEBUG=false

# Logging verbosity (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# CORS allowed origins (JSON list). Examples:
# CORS_ALLOWED_ORIGINS=["*"]
# CORS_ALLOWED_ORIGINS=["https://example.com", "https://admin.example.com"]
CORS_ALLOWED_ORIGINS=["*"]

# Base API prefix, will be useful for versioning later
API_V1_PREFIX=/api/v1

# For now, we use SQLite file in the root project
# SQLite (async):
# DATABASE_URL=sqlite+aiosqlite:///./app.db
#
# PostgreSQL (async):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
#
# TODO: Change this to the database URL of your project
DATABASE_URL=sqlite+aiosqlite:///./app.db
